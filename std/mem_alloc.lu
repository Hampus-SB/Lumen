any &mem_alloc(ui64 __size_bytes) {
    asm("\tmov rdi, 0\n");
    asm("\tmov rsi, [rbp - 8]\n");
    asm("\tmov rdx, 0x1\n");
    asm("\tor rdx, 0x2\n");
    asm("\tmov r10, 0x2\n");
    asm("\tor r10, 0x20\n");
    asm("\tmov r8, -1\n");
    asm("\tmov r9, 0\n");
    asm("\tmov rax, 9\n");
    asm("\tsyscall\n");
}
